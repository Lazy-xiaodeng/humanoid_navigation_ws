# ============================================================
# 地形分析节点参数配置
#⚠️ 顶层键需确认与 C++ 节点名一致
# ============================================================
terrain_analyzer:    # ⚠️ 如果 C++ 里节点名是 terrain_analyzer_node，改这里
  ros__parameters:

    # ===== 话题配置 =====
    map_topic: /elevation_mapping/output
    # 订阅的高程图话题
    # 必须与 elevation_mapping_params.yaml 的 output_map_topic 一致✅

    terrain_topic: /perception/terrain_info
    # 发布的地形分析结果话题（给行走控制器使用）
    # 不要修改

    safety_cloud_topic: /perception/safety_obstacles
    # 发布的虚拟墙点云话题
    # 必须与 nav2_params.yaml 的 safety_cloud.topic 一致 ✅

    # ===== ROI 分析范围 =====
    roi_x_min: 0.3
    # 分析区域前方最近距离（米，相对于 base_footprint）
    # 调整方向：
    #   → 增大（如 0.5）：忽略机器人脚下的区域，减少误判
    #   → 减小（如 0.1）：检测更近的地面，适合慢速精细行走

    roi_x_max: 1.0
    # 分析区域前方最远距离（米）
    # 调整方向：
    #   → 增大（如 1.5）：提前更远发现台阶，给导航更多反应时间
    #   → 减小（如 0.7）：只关注近处，减少误判

    roi_y_width: 0.6
    # 分析区域横向宽度（米）
    # 调整方向：
    #   → 增大（如 0.8）：检测更宽的区域，适合宽体机器人
    #   → 减小（如 0.4）：只检测机器人正前方，减少误判
    # 建议：设为机器人肩宽 × 1.2

    # ===== 安全阈值 =====
    fatal_obstacle_height: 0.40
    # 台阶高度超过此值认为不可通行（米）
    # 调整方向：
    #   → 增大（如 0.4~0.5）：允许通过更高的台阶（需要机器人腿部能力支持）
    #   → 减小（如 0.2~0.25）：更保守，小台阶也不走
    # ⚠️ 必须根据机器人实际腿部抬起高度来设置

    min_valid_data_ratio: 0.3
    # ROI 内有效数据点最低比例，低于此值不做分析
    # 调整方向：
    #   → 增大（如 0.6）：数据不足时更倾向于不分析（更保守）
    #   → 减小（如 0.2）：数据稀疏时也尝试分析（可能误判）

    safe_slope_threshold: 0.45
    # 坡度安全阈值（弧度），约 26°
    # 调整方向：
    #   → 增大（如 0.5，约28°）：允许走更陡的坡
    #   → 减小（如 0.2，约11°）：只走接近平地的区域
    # ⚠️ 建议与 elevation_mapping_params.yaml 的 max_slope 协调

    roughness_threshold: 0.12
    # 地面粗糙度阈值（米，拟合残差 RMS）
    # 调整方向：
    #   → 增大（如 0.12）：允许走更粗糙的地面（如碎石路）
    #   → 减小（如 0.05）：只走非常平整的地面

    # ===== 虚拟墙 =====
    publish_virtual_wall: true  # ★ 恢复开启（问题不在虚拟墙）
    # 是否在检测到危险地形时发布虚拟墙点云
    # 必须开启，否则 Nav2 无法感知地形危险