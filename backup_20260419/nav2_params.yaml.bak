# ==============================================================================
# 功能说明：人形机器人 3D 导航核心参数配置文件
# 适配硬件：RoboSense Airy (96线 LiDAR) 
# 任务目标：支持平地行走与楼梯/坡度环境识别
# ==============================================================================

# ============================================================================
# 行为树导航器 (BT Navigator)
# 作用：Nav2 的"大脑"，协调规划器和控制器，处理导航任务的整体流程
# ============================================================================
bt_navigator:
  ros__parameters:
    use_sim_time: False                    # 是否使用仿真时间（实机设为 False）
    global_frame: map                      # 全局坐标系，导航目标点在此坐标系下表达
    robot_base_frame: base_footprint       # 机器人底盘坐标系，用于确定机器人当前位置
    odom_frame: odom                       # 里程计坐标系，用于短期运动估计
    
    # 默认行为树 XML 文件，定义导航任务的执行逻辑
    # 使用 ROS2 官方默认文件
    default_bt_xml_filename: "navigate_to_pose_w_replanning_and_recovery.xml"

    # 行为树插件库由 ROS2 自动加载，不需要手动指定
    # plugin_lib_names 已在 ROS2 内部注册

# ============================================================================
# 控制器服务器 (Controller Server)
# 作用：接收规划路径，计算速度指令 /cmd_vel，让机器人跟踪路径
# 调参重点：速度、前瞻距离、碰撞检测
# ============================================================================
controller_server:
  ros__parameters:
    use_sim_time: False
    transform_tolerance: 2.0               # ★ 新增：TF变换时间戳容忍度，避免微小时间差导致失败

    # -------- 基础频率设置 --------
    controller_frequency: 20.0             # 控制器执行频率 (Hz)
                                           # 【调参】人形机器人建议 10-20Hz，太高会增加计算负担
    
    # -------- 速度死区阈值 --------
    # 低于这些阈值的速度会被视为零，防止机器人微小抖动
    min_x_velocity_threshold: 0.001        # X方向（前进）最小速度阈值 (m/s)
    min_y_velocity_threshold: 0.5          # Y方向（侧移）最小速度阈值 (m/s)
                                           # 【注意】人形机器人通常不支持侧移，设大一点
    min_theta_velocity_threshold: 0.001    # 旋转最小速度阈值 (rad/s)
    
    failure_tolerance: 0.3                 # 控制器失败容忍度，超过此值认为跟踪失败
    
    # -------- 进度检查器 --------
    # 检测机器人是否在移动，防止卡死
    progress_checker_plugin: "progress_checker"
    progress_checker:
      plugin: "nav2_controller::SimpleProgressChecker"
      required_movement_radius: 0.3        # 在指定时间内必须移动的最小距离 (m)
                                           # 【调参】人形机器人走得慢，可以设小一点如 0.3
      movement_time_allowance: 15.0        # 允许的最大停滞时间 (s)
                                           # 【调参】人形机器人动作慢，可以设大一点如 15.0
    
    # -------- 目标检查器 --------
    # 判断是否到达目标点
    goal_checker_plugins: ["general_goal_checker"]
    general_goal_checker:
      stateful: True                       # 状态保持，一旦到达就不再检查
      plugin: "nav2_controller::SimpleGoalChecker"
      xy_goal_tolerance: 0.25              # XY平面到达容差 (m)
                                           # 【调参】人形机器人精度有限，建议 0.2-0.3
      yaw_goal_tolerance: 0.25             # 航向角到达容差 (rad)，约14度
                                           # 【调参】人形转向不精确，建议 0.2-0.4

    # -------- 路径跟踪控制器 --------
    controller_plugins: ["FollowPath"]
    FollowPath:
      # Regulated Pure Pursuit 控制器
      # 特点：平滑、可调节速度、适合低速机器人
      plugin: "nav2_regulated_pure_pursuit_controller::RegulatedPurePursuitController"
      transform_tolerance: 2.0
      # ---- 速度设置 ----
      desired_linear_vel: 0.5              # 期望最大线速度 (m/s)
                                           # 【调参】人形机器人建议 0.3-0.6，太快会不稳
      max_linear_accel: 0.5                # 最大线加速度（人形需平稳加速）
      max_linear_decel: 0.5                # 最大线减速度
      min_approach_linear_velocity: 0.05   # 接近目标时的最小速度 (m/s)
      
      # ---- 前瞻距离 (Lookahead) ----
      # 控制器"看"多远的路径来计算转向
      lookahead_dist: 0.6                  # 默认前瞻距离 (m)
      min_lookahead_dist: 0.3              # 最小前瞻距离 (m)
      max_lookahead_dist: 0.9              # 最大前瞻距离 (m)
                                           # 【调参】人形机器人走得慢，前瞻距离可以小一点
      lookahead_time: 1.5                  # 基于时间的前瞻 (s)
      use_velocity_scaled_lookahead_dist: true     # 是否根据速度缩放前瞻距离
      
      # ---- 转向设置 ----
      rotate_to_heading_angular_vel: 1.0   # 原地转向角速度 (rad/s)
                                           # 【调参】人形机器人转向慢，建议 0.5-1.0
      use_rotate_to_heading: true          # 大角度转弯前先原地转向
                                           # 【重要】人形机器人建议开启，转弯更稳
      rotate_to_heading_min_angle: 0.2     # 角度差 > 0.5rad (~28°) 才原地转
      max_angular_accel: 1.0               # 角加速度限制

      # ---- 碰撞检测 ----
      use_collision_detection: true        # 开启碰撞检测
      max_allowed_time_to_collision_up_to_curvature: 1.0  # 碰撞预测时间 (s)
      
      # ---- 速度调节 ----
      use_regulated_linear_velocity_scaling: true   # 根据曲率调节速度
      use_cost_regulated_linear_velocity_scaling: true  # 根据代价调节速度
      cost_scaling_dist: 0.3               # 代价影响距离 (m)
      cost_scaling_factor: 0.2             # 代价缩放因子
      inflation_cost_scaling_factor: 3.0   # 膨胀层代价缩放因子
      regulated_linear_scaling_min_radius: 0.9  # 触发速度调节的最小转弯半径 (m)
      regulated_linear_scaling_min_speed: 0.15  # 调节后的最小速度 (m/s)
      
      # ---- 曲率前瞻 ----
      use_fixed_curvature_lookahead: false
      curvature_lookahead_dist: 0.25       # 曲率计算的前瞻距离 (m)

      # ---- 其他 ----
      approach_velocity_scaling_dist: 0.6  # 接近目标时开始减速的距离 (m)
      allow_reversing: true                # 是否允许倒车 (已启用)
                                           

# ============================================================================
# 局部代价地图 (Local Costmap)
# 作用：机器人周围的实时障碍物地图，用于避障和路径跟踪
# 调参重点：地图大小、更新频率、障碍物检测参数
# 图层说明：
     # static_layer（静态地图层）：把预先建好的 2D 栅格地图"铺"到代价地图上。地图中的墙壁 → 致命障碍（LETHAL=254），空闲区域 → 自由空间（FREE=0），未探索 → 未知（UNKNOWN=255
     # grid_map_layer（高程图/地形可通行性层）：读取高程图中的 erosion 层（经过安全内缩的可通行性评分），将 traversability 分数转换为代价地图代价。traversability < 0.3 → 致命障碍
     # voxel_layer（3D 体素层）：用 3D 体素网格处理点云，既能标记障碍物，也能清除已消失的障碍物（射线追踪）
     # obstacle_layer（2D 障碍物层）：与 voxel_layer 类似，但是是 2D 版本——把 3D 点云投影到 2D 平面上。没有体素网格，计算更轻量
     # inflation_layer（膨胀层）：在所有已标记的障碍物周围"膨胀"，生成渐变的代价区域。越靠近障碍物代价越高；必须放在最后	因为它需要读取前面所有层的障碍标记结果，然后计算膨胀
# ============================================================================
local_costmap:
  local_costmap:
    ros__parameters:
      transform_tolerance: 2.0
      # ---- 更新频率 ----
      update_frequency: 5.0                # 地图更新频率 (Hz)
                                           # 【调参】人形机器人走得慢，3-5Hz 足够
      publish_frequency: 2.0               # 地图发布频率 (Hz)
      
      # ---- 坐标系 ----
      global_frame: odom                   # 局部地图的参考坐标系
                                           # 【重要】必须是 odom，不能是 map（避免跳变）
      robot_base_frame: base_footprint     # 机器人底盘坐标系
      
      use_sim_time: False
      rolling_window: true                 # 滚动窗口模式，地图跟随机器人移动
      
      # ---- 地图尺寸 ----
      width: 3                             # 地图宽度 (m)
      height: 3                            # 地图高度 (m)
                                           # 【调参】人形机器人走得慢，3x3m 足够
                                           #        如果环境复杂可以增大到 4x4 或 5x5
      resolution: 0.05                     # 地图分辨率 (m/cell)，5cm
                                           # 【调参】人形机器人脚小，0.05 合适
      
      robot_radius: 0.2                    # 机器人半径 (m)，用于碰撞检测
                                           # 【调参】根据机器人实际脚部包络设置
      
      # ---- 图层配置 ----
      # 图层从下到上叠加，后面的图层会覆盖前面的
      # ★★★ 简化配置：禁用grid_map_layer，只靠点云检测障碍物（适用于平地无障碍环境）
      plugins: ["static_layer", "voxel_layer", "inflation_layer"] 
      
      
      # 1.静态地图层：提供预建地图的墙壁信息，防止局部地图"忘记"感知范围外的静态障碍
      static_layer:
        plugin: "nav2_costmap_2d::StaticLayer"
        map_subscribe_transient_local: True
      

      # 2.3D 体素层：处理 3D 点云，检测悬空障碍物（如楼梯扶手）：实时障碍检测 + 射线追踪清除旧障碍
      # 放在 grid_map 之前，这样它的 clearing 不会清除高程图的标记
      voxel_layer:
        plugin: "nav2_costmap_2d::VoxelLayer"
        enabled: True
        publish_voxel_map: True            # 发布体素地图用于调试
        
        # 体素网格参数
        origin_z: -0.05                    # 体素网格 Z 轴起点(base_footprint)
        z_resolution: 0.1                  # Z 轴分辨率 (m)
        z_voxels: 14                       # Z 轴体素数量，总高度 = 0.1 * 14 = 1.4m
        max_obstacle_height: 1.45          # 障碍物最大高度 (m)
        mark_threshold: 2                  # 标记为障碍的最小体素数
        
        # 传感器数据源
        observation_sources: pointcloud safety_cloud
        pointcloud:
          topic: /airy_points_filtered     # 过滤后的点云话题
          max_obstacle_height: 1.45        # 点云中障碍物的最大高度 (m)
          min_obstacle_height: 0.05        # 点云中障碍物的最小高度 (m)
                                           # 【调参】过滤地面，但保留台阶
                                           #        如果漏检地面障碍，减小此值
                                           #        如果地面被误检为障碍，增大此值
          clearing: True                   # 是否用于清除障碍（射线追踪）
          marking: True                    # 是否用于标记障碍
          data_type: "PointCloud2"
          raytrace_max_range: 3.0          # 射线追踪最大距离 (m)
          raytrace_min_range: 0.3          # 射线追踪最小距离 (m)
          obstacle_max_range: 2.5          # 障碍物检测最大距离 (m)
          obstacle_min_range: 0.6          # 障碍物检测最小距离 (m)
                                           # 【调参】Airy 雷达最近 0.1m，设为 0.1
        # ★★★ 接收 terrain_analyzer 的虚拟墙 ★★★
        safety_cloud:
          topic: /perception/safety_obstacles
          max_obstacle_height: 0.6         # 覆盖到脖子以上
          min_obstacle_height: -0.1        # ★★★ 接受所有高度的虚拟墙 ★★★
          clearing: False                  # ★★★ 虚拟墙只用于标记，不用于清除（避免射线追踪产生意外障碍）
          marking: True                    # 只用于标记障碍
          data_type: "PointCloud2"
          raytrace_max_range: 1.5
          obstacle_max_range: 1.5
          obstacle_min_range: 0.0

      # ★★★ 已禁用 grid_map_layer（平地环境不需要高程图地形层）
      # 3.高程图层 - 注释掉，避免订阅延迟导致costmap超时
      # grid_map_layer:
      #   plugin: "grid_map_costmap_plugin::GridMapLayer"
      #   grid_map_topic: /elevation_mapping/output
      #   enabled: True
      #   layer_name: "erosion"
      #   lethal_threshold: 0.4
      #   unknown_threshold: -1.0


      # 4.膨胀层 在障碍物周围添加"缓冲区"，让机器人保持安全距离
      inflation_layer:
        plugin: "nav2_costmap_2d::InflationLayer"
        cost_scaling_factor: 5.0           # 代价衰减因子，越大衰减越快
                                           # 【调参】人形机器人灵活，可以设大一点 (3-5)
        inflation_radius: 0.3              # 膨胀半径 (m)
                                           # 【调参】= robot_radius + 安全余量，人形机器人建议 0.4-0.6
                                                 

# ============================================================================
# 全局代价地图 (Global Costmap)
# 作用：整个环境的障碍物地图，用于全局路径规划
# 调参重点：静态地图、障碍物检测
# ============================================================================
global_costmap:
  global_costmap:
    ros__parameters:
      transform_tolerance: 2.0
      # ---- 更新频率 ----
      update_frequency: 1.0                # 更新频率 (Hz)，全局地图不需要太快
      publish_frequency: 1.0               # 发布频率 (Hz)
      
      # ---- 坐标系 ----
      global_frame: map                    # 全局地图的参考坐标系
                                           # 【重要】必须是 map
      robot_base_frame: base_footprint
      
      use_sim_time: False
      robot_radius: 0.2
      resolution: 0.05                     # 分辨率，应与静态地图一致
      track_unknown_space: true            # 跟踪未知区域
      
      # ---- 图层配置 ----
      plugins: ["static_layer", "obstacle_layer", "inflation_layer"]
      
      # ---- 静态层 ----
      # 加载预先建好的 2D 地图
      static_layer:
        plugin: "nav2_costmap_2d::StaticLayer"
        map_subscribe_transient_local: True  # 使用 transient_local QoS
      
      # ---- 障碍物层 ----
      # 实时检测的障碍物，叠加在静态地图上
      obstacle_layer:
        plugin: "nav2_costmap_2d::ObstacleLayer"
        enabled: True
        observation_sources: pointcloud
        pointcloud:
          topic: /airy_points_filtered
          max_obstacle_height: 1.45
          min_obstacle_height: 0.05        # 全局地图检测更低的障碍
                                           # 【调参】检测小障碍物如门槛
          clearing: True
          marking: True
          data_type: "PointCloud2"
          raytrace_max_range: 3.0
          obstacle_max_range: 2.5
          obstacle_min_range: 0.3
      
      # ---- 膨胀层 ----
      inflation_layer:
        plugin: "nav2_costmap_2d::InflationLayer"
        cost_scaling_factor: 2.5
        inflation_radius: 0.35

# ============================================================================
# 规划器服务器 (Planner Server)
# 作用：计算从当前位置到目标点的全局路径
# 调参重点：规划算法、转弯半径、代价权重
# ============================================================================
planner_server:
  ros__parameters:
    expected_planner_frequency: 20.0       # 期望规划频率 (Hz)
    use_sim_time: False
    planner_plugins: ["GridBased"]
    
    # ---- Smac Planner Hybrid-A* ----
    # 特点：考虑机器人运动学约束，生成平滑可执行的路径
    GridBased:
      plugin: "nav2_smac_planner::SmacPlannerHybrid"
      
      # ---- 地图处理 ----
      downsample_costmap: false            # 是否降采样代价地图
      downsampling_factor: 1               # 降采样因子
      
      # ---- 规划参数 ----
      tolerance: 0.25                      # 目标容差 (m)
      allow_unknown: true                  # 是否允许穿过未知区域
      max_iterations: 500000               # 最大迭代次数
      max_on_heading_iterations: 2000      # 沿航向的最大迭代次数
      max_planning_time: 5.0               # 最大规划时间 (s)
                                           # 【调参】如果规划超时，增大此值
      
      # ---- 运动模型 ----
      motion_model_for_search: "REEDS_SHEPP"  # 运动模型
                                           # REEDS_SHEPP: 可前进可后退
                                           # DUBIN: 只能前进
                                           # 【已修改】人形机器人支持后退,使用 REEDS_SHEPP
      
      # ---- 转弯参数 ----
      minimum_turning_radius: 0.1          # 最小转弯半径 (m)
                                           # 【调参】人形机器人可以原地转，设小一点
      angle_bin_size: 72                   # 角度离散化数量（360/72=5度一格）
      
      # ---- 代价权重 ----
      reverse_penalty: 2.5                 # 后退惩罚
      change_penalty: 0.15                 # 方向改变惩罚
      non_straight_penalty: 1.05           # 非直线惩罚
      cost_penalty: 2.0                    # 代价惩罚（靠近障碍物的惩罚）
                                           # 【调参】增大此值让路径远离障碍物
      
      # ---- 其他 ----
      retrieval_endpoints_size: 20
      retrieval_endpoints_range: 3.0

# ============================================================================
# 行为服务器 (Behavior Server)
# 作用：执行恢复行为，当机器人卡住时尝试脱困
# 调参重点：恢复动作参数
# ============================================================================
behavior_server:
  ros__parameters:
    costmap_topic: local_costmap/costmap_raw
    footprint_topic: local_costmap/published_footprint
    cycle_frequency: 10.0                  # 执行频率 (Hz)
    
    # ---- 恢复行为插件 ----
    recovery_plugins: ["spin", "backup", "wait"]
    spin:
      plugin: "nav2_behaviors::Spin"       # 原地旋转
    backup:
      plugin: "nav2_behaviors::BackUp"     # 后退
                                           
    wait:
      plugin: "nav2_behaviors::Wait"       # 等待
    
    # ---- 坐标系 ----
    global_frame: odom
    robot_base_frame: base_footprint
    transform_timeout: 0.1
    use_sim_time: False
    simulate_ahead_time: 2.0              # 后退前模拟时间

# ============================================================================
# 其他节点配置
# ============================================================================
robot_state_publisher:
  ros__parameters:
    use_sim_time: False

map_server:
  ros__parameters:
    use_sim_time: False
    yaml_filename: ""                      # 在 launch 文件中传入地图文件路径

map_saver:
  ros__parameters:
    use_sim_time: False
    save_map_timeout: 5.0                  # 保存地图超时时间 (s)
    free_thresh_default: 0.25              # 自由空间阈值
    occupied_thresh_default: 0.65          # 占据空间阈值
    map_subscribe_transient_local: True

# ============================================================================
# 生命周期管理器
# 作用：按顺序启动和管理 Nav2 各节点
# ============================================================================
lifecycle_manager_navigation:
  ros__parameters:
    use_sim_time: False
    autostart: true
    node_names: [
      'controller_server',           # 先启动 controller
      'planner_server',              # 再启动 planner
      'behavior_server',
      'bt_navigator',
      'local_costmap/local_costmap', # costmap 放在最后
      'global_costmap/global_costmap'
    ]