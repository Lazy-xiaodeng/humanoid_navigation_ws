import os
from ament_index_python.packages import get_package_share_directory
from launch import LaunchDescription
from launch_ros.actions import Node
from launch.actions import DeclareLaunchArgument, GroupAction, TimerAction
from launch.substitutions import LaunchConfiguration

def generate_launch_description():
    pkg_nav2 = get_package_share_directory('humanoid_navigation2')
    pkg_reloc = get_package_share_directory('humanoid_relocalization')
    
    nav2_params_file = os.path.join(pkg_nav2, 'config', 'nav2_params.yaml')
    reloc_params_file = os.path.join(pkg_reloc, 'config', 'relocalization_params.yaml')
    slam_params_file = os.path.join(pkg_nav2, 'config', 'slam_toolbox_params.yaml')
    bt_xml_file = os.path.join(pkg_nav2, 'behavior_tree', 'navigate_with_stairs.xml')
    map_yaml_file = os.path.join(pkg_nav2, 'maps', 'hall.yaml')
    map_posegraph = os.path.join(pkg_nav2, 'maps', 'hall')

    use_sim_time = LaunchConfiguration('use_sim_time', default='false')

    # ========== 重定位节点 (最先启动) ==========
    relocalization_node = Node(
        package='humanoid_relocalization',
        executable='relocalization_node',
        name='relocalization_node',
        output='screen',
        parameters=[reloc_params_file, {'use_sim_time': use_sim_time}]
    )

    # ========== 点云转激光 (延迟1秒) ==========
    pc_to_scan_node = TimerAction(
        period=1.0,
        actions=[
            Node(
                package='pointcloud_to_laserscan',
                executable='pointcloud_to_laserscan_node',
                name='pointcloud_to_laserscan',
                remappings=[
                    ('cloud_in', '/fast_lio/cloud_registered'),
                    ('scan', '/scan')
                ],
                parameters=[{
                    'use_sim_time': use_sim_time,
                    'target_frame': 'base_footprint',
                    'min_height': 0.1,
                    'max_height': 1.2,
                    'range_min': 0.6,
                    'range_max': 30.0,
                    'scan_time': 0.1,
                    'transform_tolerance': 2.0,
                    'inf_epsilon': 1.0,
                    'use_inf': True,
                    'queue_size': 50,
                }]
            )
        ]
    )

    # ========== Nav2 核心节点 (延迟3秒) ==========
    nav_nodes = TimerAction(
        period=3.0,
        actions=[
            GroupAction([
                # 1. slam_toolbox 定位模式
                Node(
                    package='slam_toolbox',
                    executable='localization_slam_toolbox_node',
                    name='slam_toolbox',
                    parameters=[
                        slam_params_file,
                        {
                            'use_sim_time': use_sim_time,
                            'map_file_name': map_posegraph,
                        }
                    ]
                ),
                
                # 2. 规划服务器
                Node(
                    package='nav2_planner',
                    executable='planner_server',
                    name='planner_server',
                    output='screen',
                    parameters=[nav2_params_file, {'use_sim_time': use_sim_time}]
                ),

                # 3. 控制服务器
                Node(
                    package='nav2_controller',
                    executable='controller_server',
                    output='screen',
                    parameters=[nav2_params_file, {'use_sim_time': use_sim_time}]
                ),

                # 4. 行为服务器
                Node(
                    package='nav2_behaviors',
                    executable='behavior_server',
                    name='behavior_server',
                    output='screen',
                    parameters=[nav2_params_file, {'use_sim_time': use_sim_time}]
                ),

                # 5. 行为树导航
                Node(
                    package='nav2_bt_navigator',
                    executable='bt_navigator',
                    name='bt_navigator',
                    output='screen',
                    parameters=[
                        nav2_params_file, 
                        {
                            'use_sim_time': use_sim_time,
                            'default_bt_xml_filename': bt_xml_file
                        }
                    ]
                ),

                # 6. 生命周期管理（最后启动）
                Node(
                    package='nav2_lifecycle_manager',
                    executable='lifecycle_manager',
                    name='lifecycle_manager_navigation',
                    output='screen',
                    parameters=[
                        {'use_sim_time': use_sim_time},
                        {'autostart': True},
                        {'bond_timeout': 0.0},
                        {'node_names': [ 
                            'slam_toolbox',
                            'planner_server', 
                            'controller_server', 
                            'behavior_server', 
                            'bt_navigator'
                        ]}
                    ]
                )
            ])
        ]
    )

    return LaunchDescription([
        DeclareLaunchArgument('use_sim_time', default_value='false'),
        relocalization_node,
        pc_to_scan_node,
        nav_nodes
    ])

