  <!-- ========================================== -->
  <!-- 2. 激光雷达内置 IMU 框架 (供 FAST-LIO 使用)  -->
  <!-- ========================================== -->
  <!-- <link name="rslidar_imu">
  </link>

  <joint name="rslidar_imu_joint" type="fixed">
    <parent link="rslidar"/>
    <child link="rslidar_imu"/>
    <origin xyz="0.004250 0.004180 -0.004460" rpy="3.139132 -0.001422 -1.569322"/>
  </joint> -->

  <!-- 添加IMU框架 -->
  <link name="imu_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.0" rpy="0 0 0"/> 
  </joint>

  <!-- 导航相关参数 -->
  <xacro:property name="robot_radius" value="0.3" />
  <xacro:property name="footprint_padding" value="0.05" />

</robot>