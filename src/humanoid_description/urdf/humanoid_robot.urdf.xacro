<?xml version="1.0" encoding="utf-8"?>
<robot name="humanoid_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- 包含原始URDF内容 -->
  <xacro:include filename="$(find humanoid_description)/urdf/HU_D04_01.urdf" />

  <!-- ========================================== -->
